{
  "kind": "collectionType",
  "collectionName": "jogos",
  "info": {
    "singularName": "jogo",
    "pluralName": "jogos",
    "displayName": "Jogos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "externalId": {
      "type": "integer",
      "unique": true
    },
    "equipa_casa": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team",
      "inversedBy": "jogos_casa"
    },
    "equipa_fora": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team",
      "inversedBy": "jogos_fora"
    },
    "estadio": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::estadio.estadio",
      "inversedBy": "jogos"
    },
    "data": {
      "type": "datetime"
    },
    "fase": {
      "type": "string"
    },
    "estado": {
      "type": "enumeration",
      "enum": [
        "Agendado",
        "A decorrer",
        "Terminado"
      ],
      "default": "Agendado"
    },
    "golos_casa": {
      "type": "integer",
      "default": 0
    },
    "golos_fora": {
      "type": "integer",
      "default": 0
    }
  }
}
